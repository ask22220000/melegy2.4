# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env.local and fill in the actual values
# NEVER commit .env.local to git!

# ========================================
# PUBLIC VARIABLES (Safe to expose)
# Use NEXT_PUBLIC_ prefix for client-side
# ========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_APP_URL=https://melegy.app

# ========================================
# PRIVATE VARIABLES (Server-only)
# DO NOT use NEXT_PUBLIC_ prefix
# These will never be exposed to the client
# ========================================

# Gemini API Keys (comma-separated for rotation)
GEMINI_API_KEYS=key1,key2,key3

# Perplexity API
PERPLEXITY_API_KEY=your-perplexity-key

# Supabase (Private)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Payment Processing
KASHIER_MERCHANT_ID=your-merchant-id
KASHIER_SECRET_KEY=your-secret-key

# WhatsApp Integration (if used)
WHATSAPP_ACCESS_TOKEN=your-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-account-id

# File Processing Services
FAL_API_KEY=your-fal-key
REMOVEBG_API_KEY=your-removebg-key

# Node Environment
NODE_ENV=production

# ========================================
# SECURITY
# ========================================
# These should be set automatically
NEXT_PUBLIC_ENVIRONMENT=production
SECURE_API_ENABLED=true
