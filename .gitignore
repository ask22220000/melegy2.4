.env.local
.env.production.local
.env.test.local
.env.development.local

# Source maps (should be disabled in production)
*.map
.next/static/**/*.map

# IDE
.vscode
.idea
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# logs
logs/
*.log
